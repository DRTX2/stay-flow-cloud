// DEV ONLY — These values are for local development.
// This file is intentionally NOT in .gitignore because it contains NO real secrets —
// only local dev defaults that are harmless to expose.
// For production secrets, use environment variables, Azure Key Vault, or GitHub Secrets.
//
// To connect to Neon (recommended), paste your Neon connection string below.
// Get it from: https://console.neon.tech → Connect → Connection string
// Use the NON-pooler URL for the migrator (run migrations from StayFlow.MigrationHost).
// Use the pooler URL for the app connection string (higher concurrency).
{
  "ConnectionStrings": {
    // Neon pooler connection — used by the API at runtime.
    // Format: postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<dbname>?sslmode=require
    "Default": "",

    // Neon direct (non-pooler) — used by StayFlow.MigrationHost for migrations.
    // Format: postgresql://<user>:<password>@<host>.<region>.aws.neon.tech/<dbname>?sslmode=require
    // Set STAYFLOW_MIGRATOR_CONNECTION env var instead if you prefer not to put it here.
    "Migrator": "",

    // Optional: local Redis for caching / sessions. Leave empty to disable Redis (in-memory fallback).
    "Redis": "",

    // Optional: local MongoDB for audit logs. Leave empty to disable (no-op audit store).
    "Mongo": ""
  },
  "Authentication": {
    // Secret for the machine-to-machine OAuth2 client (stayflow-service).
    // In production, set Authentication__ServiceClientSecret as an environment variable.
    "ServiceClientSecret": "dev-service-secret-change-in-prod",
    // URL of the Next.js sign-in page. The backend redirects OAuth2 login challenges here
    // so the backend never serves any frontend HTML.
    // In production set Authentication__FrontendLoginUrl to your deployed frontend URL.
    "FrontendLoginUrl": "http://localhost:3000/auth/signin"
  },
  "Seeding": {
    // Admin credentials for the first-boot seed. These become the SuperAdmin login.
    // In production, set Seeding__AdminEmail and Seeding__AdminPassword as env vars.
    "AdminEmail": "admin@stayflow.local",
    "AdminPassword": "Admin123$"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "RateLimiting": {
    // Disable rate limiting in local dev to avoid throttling during development.
    "Enabled": false
  },
  // CORS: Next.js dev server origin. Set FrontendOrigin env var in production.
  "FrontendOrigin": "http://localhost:3000"
}
