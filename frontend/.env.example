# --- Public (exposed to the browser) ---------------------------------------
# Canonical site URL (used for metadata, OAuth redirect_uri, sitemap/robots).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Browser-facing OpenIddict authority (authorize / end-session endpoints).
NEXT_PUBLIC_OIDC_AUTHORITY=http://localhost:8080

# --- Server only -----------------------------------------------------------
# Server-to-server base URL for the .NET API (data fetching + token exchange).
# In Docker this is the service name, e.g. http://stayflow.api:8080
API_INTERNAL_URL=http://localhost:8080
# OAuth client id (public client, Authorization Code + PKCE).
OIDC_CLIENT_ID=stayflow-spa
# OAuth scope requested by the BFF.
OIDC_SCOPE=openid profile email roles stayflow.api offline_access
