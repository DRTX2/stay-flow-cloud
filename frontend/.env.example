# API + OAuth2 authority (the ASP.NET Core API). Leave both empty to use the Vite dev proxy
# (same-origin), which avoids CORS on the token endpoint. Set them only for a cross-origin setup.
VITE_API_URL=
VITE_OIDC_AUTHORITY=

# Seeded public SPA client (Authorization Code + PKCE).
VITE_OIDC_CLIENT_ID=stayflow-spa
VITE_OIDC_SCOPE=openid profile email roles stayflow.api offline_access
VITE_OIDC_REDIRECT_URI=http://localhost:5173/callback
