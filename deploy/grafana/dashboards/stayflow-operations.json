{
  "annotations": { "list": [] },
  "editable": true,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["stayflow", "operations"],
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "utc",
  "title": "StayFlow Jobs, Messaging & Notifications",
  "uid": "stayflow-operations",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Outbox pending",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 10 }, { "color": "red", "value": 100 }] } }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "stayflow_outbox_pending_messages" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Oldest outbox message",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 60 }, { "color": "red", "value": 300 }] } }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "stayflow_outbox_oldest_age_seconds" }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Notification outcomes",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "sum by (channel, outcome) (rate(stayflow_notification_notifications_total[5m]))", "legendFormat": "{{channel}} {{outcome}}" }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Job outcomes",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "sum by (job, outcome) (rate(stayflow_job_outcome_runs_total[15m]))", "legendFormat": "{{job}} {{outcome}}" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Business and integration events",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "sum by (event) (rate(stayflow_business_event_events_total[5m]))", "legendFormat": "{{event}}" }]
    }
  ],
  "templating": { "list": [] }
}
