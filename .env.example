# ─────────────────────────────────────────────────────────────────────────────
# StayFlow Cloud — Environment Variables Reference
#
# Copy this file to `.env` (local dev) and fill in real values.
# NEVER commit `.env` to source control.
#
# Environments:
# - Local: copy to `.env` and use development-only values.
# - Demo: use a disposable database and explicitly labelled demo credentials.
# - Production: set all secrets in Azure Container Apps / GitHub Actions / Key Vault,
#   not in a file. Never reuse local/demo credentials in production.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────

# App connection string — uses the Neon CONNECTION POOLER endpoint.
# Get it from: Neon Dashboard → Connect → Connection pooling ON → copy "Connection string"
# Format: postgresql://stayflow_app:<password>@<host>-pooler.<region>.aws.neon.tech/<dbname>?sslmode=require&channel_binding=require
ConnectionStrings__Default=

# Migrator connection string — uses the Neon DIRECT endpoint (NO pooler).
# Required by StayFlow.MigrationHost for DDL operations.
# Get it from: Neon Dashboard → Connect → Connection pooling OFF → copy "Connection string"
# Format: postgresql://stayflow_migrator:<password>@<host>.<region>.aws.neon.tech/<dbname>?sslmode=require
STAYFLOW_MIGRATOR_CONNECTION=

# ─── Optional Infrastructure ─────────────────────────────────────────────────

# Redis connection string (leave empty to use in-memory cache in dev)
ConnectionStrings__Redis=

# MongoDB connection string for audit logs (leave empty to disable)
ConnectionStrings__Mongo=

# ─── Auth / OAuth ─────────────────────────────────────────────────────────────

# Secret for the machine-to-machine OAuth2 client (stayflow-service).
# Generate with: openssl rand -base64 32
Authentication__ServiceClientSecret=

# Optional smoke-test client used by `make smoke-staging`.
# Create this as a client-credentials app in the target environment with read access to
# health-adjacent operational APIs (at minimum analytics:view for front-desk smoke checks).
SMOKE_CLIENT_ID=
SMOKE_CLIENT_SECRET=
STAGING_API_URL=

# Optional: have StayFlow.MigrationHost seed the smoke client automatically.
# These values should match SMOKE_CLIENT_ID / SMOKE_CLIENT_SECRET in your CI smoke step.
Authentication__SmokeClientId=
Authentication__SmokeClientSecret=
Authentication__SmokeTenantSlug=grand-demo

# ─── Frontend / BFF ───────────────────────────────────────────────────────────

# Browser-facing site URL and OIDC authority. Do not put secrets in NEXT_PUBLIC_* values.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_OIDC_AUTHORITY=http://localhost:8080

# Server-to-server API URL used by the Next.js BFF.
API_INTERNAL_URL=http://localhost:8080

# First-party OIDC public client id. Public clients do not have a secret.
OIDC_CLIENT_ID=stayflow-spa
OIDC_SCOPE=openid profile email roles stayflow.api offline_access

# ─── Seeding (used by StayFlow.MigrationHost -- seed) ───────────────────────

# Admin user credentials created on first seed.
# Local/demo only: use disposable credentials and never display them on public pages.
# Production: set a strong secret through your deployment secret store.
Seeding__AdminEmail=admin@yourdomain.com
Seeding__AdminPassword=

# ─── Social Login (optional — leave empty to disable each provider) ───────────

Authentication__Google__ClientId=
Authentication__Google__ClientSecret=

Authentication__Microsoft__ClientId=
Authentication__Microsoft__ClientSecret=

Authentication__GitHub__ClientId=
Authentication__GitHub__ClientSecret=

# ─── AWS S3 (document storage, optional) ─────────────────────────────────────

AWS__AccessKeyId=
AWS__SecretAccessKey=
AWS__Region=us-east-1
AWS__S3BucketName=stayflow-documents
