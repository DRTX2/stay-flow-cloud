# Leave these empty to use the Vite dev proxy (same-origin) — recommended for local dev, since it
# avoids CORS on the OAuth2 token endpoint. Set them only for a cross-origin deployment.
VITE_API_URL=
VITE_OIDC_AUTHORITY=

# Seeded public SPA client (Authorization Code + PKCE).
VITE_OIDC_CLIENT_ID=stayflow-spa
VITE_OIDC_SCOPE=openid profile email roles stayflow.api offline_access
VITE_OIDC_REDIRECT_URI=http://localhost:5173/callback

# Where the dev server proxies /api, /connect, /account (the ASP.NET Core API).
VITE_PROXY_TARGET=http://localhost:8080
